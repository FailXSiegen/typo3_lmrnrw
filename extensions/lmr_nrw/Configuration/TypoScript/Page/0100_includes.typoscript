page{
    includeCSS {
        abovethefold = EXT:lmr_nrw/Resources/Public/StyleSheet/abovethefold.css
        abovethefold.inline = 1
        abovethefold.forceOnTop = 1
        abovethefold.media = all
        fonts = EXT:lmr_nrw/Resources/Public/StyleSheet/fonts.css
        lmrnrw = EXT:lmr_nrw/Resources/Public/StyleSheet/lmrnrw.css
    }
    includeJSFooter {
        bootstrap = EXT:lmr_nrw/Resources/Public/JavaScript/bootstrap.js
        main_javascript = EXT:lmr_nrw/Resources/Public/JavaScript/javascript.js
    }
}