{
    "name": "riconet/t3-project-lmrnrw",
    "description": "",
    "license": "GPL-3.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "extensions/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "platform": {
            "php": "8.2"
        },
		"allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true,
            "helhum/dotenv-connector": true
        }
    },
    "require": {
		"php": "^8.2",
		"phpdocumentor/reflection-docblock": "^5.1",
		"typo3/cms-backend": "^13.4",
		"typo3/cms-core": "^13.4",
		"typo3/cms-extbase": "^13.4",
		"typo3/cms-extensionmanager": "^13.4",
		"typo3/cms-filelist": "^13.4",
		"typo3/cms-fluid": "^13.4",
		"typo3/cms-frontend": "^13.4",
		"typo3/cms-install": "^13.4",
		"typo3/cms-recordlist": "^13.4",
		"typo3/cms-about": "^13.4",
		"typo3/cms-belog": "^13.4",
		"typo3/cms-beuser": "^13.4",
		"typo3/cms-felogin": "^13.4",
		"typo3/cms-fluid-styled-content": "^13.4",
		"typo3/cms-form": "^13.4",
		"typo3/cms-impexp": "^13.4",
		"typo3/cms-info": "^13.4",
		"typo3/cms-rte-ckeditor": "^13.4",
		"typo3/cms-setup": "^13.4",
		"typo3/cms-sys-note": "^13.4",
		"typo3/cms-t3editor": "^13.4",
		"typo3/cms-tstemplate": "^13.4",
		"typo3/cms-viewpage": "^13.4",
		"typo3/cms-lowlevel": "^13.4",
		"typo3/cms-recycler": "^13.4",
		"typo3/cms-seo": "^13.4",
		"typo3/cms-redirects": "^13.4",
		"typo3/cms-dashboard": "^13.4",
		"typo3/cms-scheduler": "^13.4",
		"helhum/typo3-console": "^8",
		"helhum/dotenv-connector": "^3",
		"georgringer/news": "^12.3",
		"b13/container": "^3",
		"t3/min": "^3",
		"tpwd/ke_search": "^6",
		"failx/lmr_nrw": "@dev",
		"friendsoftypo3/tt-address": "^9",
		"in2code/powermail": "^13",
		"georgringer/numbered-pagination": "^2"
	},
    "require-dev": {
		"deployer/deployer": "^7"
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "web-dir": "public"
        }
    },
	"minimum-stability": "dev",
	"prefer-stable": true
}
